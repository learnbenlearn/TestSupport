/**
 * Enum for generator execution mode. Can be set as a shorthand to determine if a single record (`SINGLE_RECORD`) or 200 records (`BULK_RECORDS`)
 * are generated by calls to `generate()`.
 * @author Ben Learn
 * @since 06-24-2026
 * @group Config
 */
public enum TSGeneratorMode {
    SINGLE_RECORD,
    BULK_RECORDS
}